# .env.example — copy to a local `.env` (gitignored) and fill in real values. NEVER commit a real .env.
# VITE_* are PUBLIC (bundled into the browser app) and safe to expose. Everything else is server-side.
# Secrets are marked  # SECRET. I (the build agent) will walk you through the Auth0 + Microsoft setup.

# ─── Auth0 — login + API authorization ──────────────────────────────────────────
# Setup (guided): create a SPA application + an API (its identifier = the audience below),
# add a permission e.g. `reconcile:commits`, enable RBAC + "Add Permissions in the Access Token".
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id
VITE_AUTH0_AUDIENCE=https://api.wcm                  # the API identifier you choose
AUTH0_ISSUER_URI=https://your-tenant.us.auth0.com/   # trailing slash required
AUTH0_AUDIENCE=https://api.wcm                        # MUST equal VITE_AUTH0_AUDIENCE
# Optional — only if we sync users/roles via the Auth0 Management API (not used by default):
# AUTH0_M2M_CLIENT_ID=
# AUTH0_M2M_CLIENT_SECRET=                             # SECRET

# ─── Microsoft Graph — Outlook delegated /me/events ─────────────────────────────
# Setup (guided): spin up a FREE Microsoft 365 developer tenant, register a Web (confidential) app,
# add DELEGATED perms Calendars.ReadWrite + User.Read + offline_access, register the redirect URI,
# grant admin consent if required.
AZURE_TENANT_ID=your_entra_tenant_id
AZURE_CLIENT_ID=your_app_registration_client_id
AZURE_CLIENT_SECRET=                                  # SECRET — client secret from the app registration
AZURE_REDIRECT_URI=http://localhost:8080/api/graph/callback   # prod: https://<deployed-host>/api/graph/callback
# GRAPH_SCOPES=offline_access Calendars.ReadWrite User.Read    # optional override of the defaults
GRAPH_TOKEN_ENC_KEY=                                  # SECRET — generated at build time; do not hand-edit

# ─── Local database — docker-compose Postgres 16.4 ──────────────────────────────
POSTGRES_DB=wcm
POSTGRES_USER=wcm
POSTGRES_PASSWORD=change_me_locally                   # use a non-default value locally
DB_URL=jdbc:postgresql://localhost:5432/wcm

# ─── App ────────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:5173                    # host-shell origin (Graph deep-links / redirects)

# ─── AWS — deploy (real creds live in ~/gauntlet/.env, NOT here) ─────────────────
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY / AWS_ACCOUNT_ID / AWS_S3_BUCKET are read from
# ~/gauntlet/.env at deploy time. CDK pushes backend secrets into AWS Secrets Manager.
AWS_DEFAULT_REGION=us-east-1
