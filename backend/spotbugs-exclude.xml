<?xml version="1.0" encoding="UTF-8"?>
<!--
  SpotBugs exclude filter for the Weekly Commit Module backend.
  Narrowly suppresses CT_CONSTRUCTOR_THROW on domain entities that validate their invariants in the
  constructor (a deliberate, common JPA/DDD pattern): the throw guards a malformed entity, and these
  classes are not exposed to untrusted finalizer-attack subclassing. All other detectors stay active.
-->
<FindBugsFilter>
  <Match>
    <Class name="com.solovis.wcm.commit.PulseReading"/>
    <Bug pattern="CT_CONSTRUCTOR_THROW"/>
  </Match>
</FindBugsFilter>
