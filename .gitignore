# AI conversation logs (ai-logging skill) — local history, not for the repo
ai-logging/*conversation*.md
ai-logging/*conversation*.md.bak*
*.bak-*

# Claude Code local settings (per-machine hooks/permissions)
.claude/settings.local.json

# Claude Flow local runtime state (session metrics, edit-tracking — machine-local)
.claude-flow/

# Assignment source screenshots (transcribed into assignment_description.md)
Screenshot*.png

# Assignment brief — kept local, not published to the repo
assignment_description.md

# Internal research dossier (wcm-research workflow output) — local notes, not for the repo
docs/research/

# Design brief for Claude Design — local handoff artifact, not for the repo
design/

# Python bytecode cache
__pycache__/
*.pyc

# Java / Maven build output
backend/target/
target/

# Node / Nx / build output
node_modules/
.nx/
dist/
**/dist/
*.tsbuildinfo

# Module Federation build temp (@module-federation/vite scaffolding)
.__mf__temp/
**/.__mf__temp/

# E2E run artifacts (Cypress + Playwright) — generated per run, not source
e2e/cypress/screenshots/
e2e/cypress/videos/
e2e/cypress/downloads/
e2e/test-results/
e2e/playwright-report/
e2e/.last-run.json

# Test-result / coverage artifacts — generated per run (uploaded by CI), not source
coverage/
**/coverage/
perf/k6-summary.json

# Internal planning / process docs — kept local (like research/design); deliverable docs go in README/docs/TECHNICAL.md
docs/plans/
docs/planning/
docs/change-board.md

# Demo / interview scripts — working artifacts (the recorded video is the deliverable), kept local
docs/DEMO_SCRIPT.md
docs/DEMO_SCRIPT_R2.md

# Generated learning-site app — a creation artifact built from docs/layers/; not a deliverable
# and not needed to build or deploy WCM (also excluded from the Docker build via .dockerignore)
docs/learn-site/

# Secrets — never commit real env files (Auth0/Azure/AWS); keep .env.example only
.env
.env.*
!.env.example

# Handoff docs (context-management; per-machine, not for the repo)
handoff/

# Deploy-time secrets (per-machine, not for the repo)
deploy/.env
*.pem
deploy/.ec2-state
deploy/.*.pem
